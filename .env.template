# Copy to .env and adjust values:  cp .env.template .env

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=drawings
# Host port mapped to the DB container (use 5433 if 5432 is taken).
POSTGRES_PORT=5432

# --- Service host ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Backend CORS ---
# Comma-separated allowed origins, or * for any.
CORS_ORIGINS=*

# --- Moderation ---
# Secret key for /moderate page and moderation API.
MODERATION_SECRET_KEY=1111
